    "@sentry/node": "^10.53.1",
    "@upstash/redis": "^1.32.0",
    "@zeropay/shared-types": "*",
    "axios": "^1.7.2",
    "bech32": "^2.0.0",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-basic-auth": "^1.2.1",
    "firebase-admin": "^12.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
