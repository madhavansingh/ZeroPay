# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/zeropay?retryWrites=true&w=majority

# ─── Firebase Admin SDK ─────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=zeropay-xxxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@zeropay-xxxxx.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://zeropay-xxxxx-default-rtdb.asia-southeast1.firebasedatabase.app

# ─── Upstash Redis (REST — for caching) ────────────────────────────────────────
# Get from: https://console.upstash.com → Redis → Your DB → REST API
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Upstash Redis (TLS ioredis — for BullMQ) ──────────────────────────────────
# Get from: https://console.upstash.com → Redis → Your DB → Details → Endpoint
# Format: rediss://:<password>@<host>:<port>
UPSTASH_REDIS_TLS_URL=rediss://:your-password@xxxxx.upstash.io:6380

# ─── Blockfrost ─────────────────────────────────────────────────────────────────
# Get from: https://blockfrost.io → Dashboard → Add project → Cardano preprod
BLOCKFROST_PROJECT_ID=preprodXXXXXXXXXXXXXXXX
BLOCKFROST_NETWORK=preprod

# ─── Pinata IPFS ────────────────────────────────────────────────────────────────
# Get from: https://app.pinata.cloud → API Keys → New Key
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_JWT=your_pinata_jwt_token

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://zeropay.vercel.app

# ─── App Config ────────────────────────────────────────────────────────────────
MIN_CONFIRMATIONS=3
HIGH_VALUE_THRESHOLD_USD=500
HIGH_VALUE_CONFIRMATIONS=6
INVOICE_EXPIRY_DEFAULT_SECONDS=600
