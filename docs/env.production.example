# ZeroPay Production Environment Variables Template
# Copy this file to .env in your backend deployment directory and populate the actual secrets.

# ── SERVER CONFIGURATION ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# CORS Allowed Origins (Comma-separated list of frontends)
ALLOWED_ORIGINS=https://zeropay.example.com,https://zeropay-customer.example.com

# ── DATABASE CONFIGURATION ────────────────────────────────────────────────────
# MongoDB Connection String (e.g. MongoDB Atlas production URL)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/zeropay-prod?retryWrites=true&w=majority

# ── REDIS CONFIGURATION (UPSTASH OR REDIS CLOUD WITH TLS) ────────────────────
# ioredis compatible TLS Redis URL (Used by BullMQ workers)
# Note: For Upstash, ensure the scheme is rediss:// and TLS is enabled.
UPSTASH_REDIS_TLS_URL=rediss://default:<password>@<endpoint>.upstash.io:6379

# Upstash REST API URLs (Used by pricing cache/rate limit fallback)
UPSTASH_REDIS_REST_URL=https://<endpoint>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your_rest_token>

# ── BLOCKCHAIN CONFIGURATION (CARDANO BLOCKFROST) ────────────────────────────
# Blockfrost API keys (Ensure this matches the network you are running)
BLOCKFROST_PROJECT_ID=preprod<your_blockfrost_project_key>
# Network options: mainnet, preprod, preview
BLOCKFROST_NETWORK=preprod

# ── FILE & RECEIPT ARCHIVE CONFIGURATION (PINATA IPFS) ────────────────────────
# Pinata credentials for pinning receipts on IPFS
PINATA_API_KEY=<your_pinata_api_key>
PINATA_SECRET_KEY=<your_pinata_secret_key>
PINATA_JWT=<your_pinata_jwt_bearer_token>

# ── FIREBASE ADMINISTRATIVE & AUTHENTICATION SERVICES ─────────────────────────
# Firebase Service Account Credentials (used by firebase-admin SDK)
FIREBASE_PROJECT_ID=zeropay-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@zeropay-prod.iam.gserviceaccount.com
# Private key should include newline escaping if written inline
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"
# Firebase Realtime Database URL
FIREBASE_DATABASE_URL=https://zeropay-prod-default-rtdb.firebaseio.com/

# ── APPLICATION SETTINGS ──────────────────────────────────────────────────────
MERCHANT_ID_PREFIX=MC
# Minimum confirmations required on-chain for standard ADA payments
MIN_CONFIRMATIONS=3
# High value payments threshold (in USD)
HIGH_VALUE_THRESHOLD_USD=500
# Confirmations required for high value payments to mitigate double-spend / chain reorganizations
HIGH_VALUE_CONFIRMATIONS=6
# Invoice expiration TTL (in seconds)
INVOICE_EXPIRY_DEFAULT_SECONDS=600

# ── OPTIONAL: MONITORING & SECURITY ──────────────────────────────────────────
# Sentry DSN for error reporting
SENTRY_DSN=https://<key>@o123456.ingest.sentry.io/<project_id>
# Basic Auth Credentials for Bull Board Queue Admin UI
ADMIN_USERNAME=zeropay-admin
ADMIN_PASSWORD=<strong_admin_password_here>
