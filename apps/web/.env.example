# ─── Firebase Web SDK ──────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your Apps → Web App → Config
VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=zeropay-xxxxx.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://zeropay-xxxxx-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=zeropay-xxxxx
VITE_FIREBASE_STORAGE_BUCKET=zeropay-xxxxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxx

# ─── Backend API ────────────────────────────────────────────────────────────────
# In development, Vite proxies /api to localhost:4000, so leave this commented
# For production, set to your deployed backend URL
# VITE_API_URL=https://api.zeropay.io/api/v1
